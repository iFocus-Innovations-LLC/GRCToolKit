#!/usr/bin/env bash
# AU-2 Audit Events — read-only probes.
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f /usr/local/sbin/grc-audit-probes-common.sh ]; then
  # shellcheck source=/usr/local/sbin/grc-audit-probes-common.sh
  source /usr/local/sbin/grc-audit-probes-common.sh
else
  # shellcheck source=common.sh
  source "${DIR}/common.sh"
fi

grc_probe_header "AU-2"
grc_run_readonly "auditd_active" systemctl is-active auditd
grc_run_readonly "audit_rules_count" bash -c "grep -c '^[^#]' /etc/audit/rules.d/audit.rules 2>/dev/null || echo 0"
grc_run_readonly "audit_log_files" bash -c "find /var/log/audit -maxdepth 1 -name 'audit.log*' -type f 2>/dev/null | wc -l"
grc_run_readonly "audit_log_stat" stat -c '%a %U %G' /var/log/audit/audit.log
grc_probe_footer
