# Copy to grc-deploy.env (or another path), fill values, chmod 600.
# Every setting must look like VAR=value — not a bare value on its own line.
# Load with: GRC_DEPLOY_ENV_FILE=./grc-deploy.env ./scripts/deploy.sh staging
#            or ./scripts/deploy.sh --env-file ./grc-deploy.env staging
#
# Required
GCP_PROJECT_ID=
GKE_CLUSTER_NAME=
GCP_REGION=us-central1

# Optional defaults
GAR_LOCATION=us-central1
REPOSITORY=grc-toolkit
SERVICE=grc-toolkit

# Optional: remove this file when deploy exits (set GRC_DEPLOY_CLEANUP_ENV_FILE=0 to skip auto-cleanup
# of temp paths when using ./scripts/deploy.sh --silent). See scripts/deploy.sh --cleanup-env-file.
# GRC_DEPLOY_CLEANUP_ENV_FILE=1

# App secret for deploy script (alternative: k8s/secret.yaml, not tracked)
# GEMINI_API_KEY=
