# Kubernetes Secret template - DO NOT commit secret.yaml with real values
# Copy to secret.yaml and fill in your base64-encoded values, or use scripts/update-secret.sh
#
# To create secret from API key:
#   ./scripts/update-secret.sh "YOUR_GEMINI_API_KEY"
#
# Or manually encode and apply:
#   echo -n "YOUR_ACTUAL_API_KEY" | base64
apiVersion: v1
kind: Secret
metadata:
  name: grc-toolkit-secrets
  namespace: grc-toolkit
type: Opaque
data:
  gemini-api-key: <BASE64_ENCODED_GEMINI_API_KEY>
